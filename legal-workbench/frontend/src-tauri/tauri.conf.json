{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Legal Workbench",
  "version": "0.1.4",
  "identifier": "br.com.lexvector.workbench",
  "build": {
    "beforeDevCommand": "bun run tauri:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Legal Workbench",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://100.114.203.28 http://localhost:* https://*.lexvector.com.br ws://100.114.203.28 ws://localhost:*; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2QjIyRjQ1NzE3MTBCMTcKUldRWEMzRnhSUyt5aGlWWjhURUhwblJ1R0VwbkJXeUtlYjI3SDVPRDVHNDR2bzg2VlJnUUI3a3AK",
      "dangerousInsecureTransportProtocol": true,
      "endpoints": [
        "http://100.114.203.28:8090/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
